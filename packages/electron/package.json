{
  "name": "@vibeeditor/electron",
  "version": "0.1.0",
  "private": true,
  "description": "VibeEditor Electron desktop app",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "VibeEditor",
  "dependencies": {},
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.vibeeditor.app",
    "productName": "VibeEditor",
    "electronVersion": "28.3.3",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "../web/dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
