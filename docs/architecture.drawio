    </mxCell>

    <!-- ===== SECTION 3: 文件系统层 ===== -->
    <mxCell id="sec3-label" value="文件系统抽象层" style="text;html=1;strokeColor=none;fillColor=#eeeeee;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="30" y="715" width="140" height="24" as="geometry"/>
    </mxCell>

    <!-- IFileSystem 接口 -->
    <mxCell id="fs-interface" value="&lt;&lt;接口&gt;&gt;&lt;br&gt;&lt;b&gt;IFileSystem&lt;/b&gt; (core 包)&lt;br&gt;readFile · writeFile · deleteFile · readDir&lt;br&gt;createDir · deleteDir · exists · stat&lt;br&gt;rename · watch · dispose" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;fontStyle=0;" vertex="1" parent="1">
      <mxGeometry x="30" y="750" width="270" height="70" as="geometry"/>
    </mxCell>

    <!-- 3种实现 -->
    <mxCell id="fs-local" value="&lt;b&gt;LocalFileSystem（本地文件系统）&lt;/b&gt;&lt;br&gt;基于 Node.js fs/promises&lt;br&gt;支持 fs.watch 文件监听&lt;br&gt;用于: Server后端、Electron IPC、CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e0;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="30" y="840" width="195" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="fs-server" value="&lt;b&gt;ServerFileSystem（远程文件系统）&lt;/b&gt;&lt;br&gt;HTTP REST 代理模式&lt;br&gt;支持 Bearer Token 认证&lt;br&gt;用于: 浏览器→服务器通信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="245" y="840" width="195" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="fs-virtual" value="&lt;b&gt;VirtualFileSystem（虚拟文件系统）&lt;/b&gt;&lt;br&gt;纯内存 Map 树结构&lt;br&gt;自动创建中间目录&lt;br&gt;用于: 测试、沙箱环境" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3ebf7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="460" y="840" width="195" height="60" as="geometry"/>
    </mxCell>

    <!-- 实现箭头 -->
    <mxCell id="edge-fs-local" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=1;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1" source="fs-local" target="fs-interface">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-fs-server" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;strokeWidth=1;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1" source="fs-server" target="fs-interface">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-fs-virtual" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=1;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1" source="fs-virtual" target="fs-interface">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- IAgentFileSystem -->
    <mxCell id="fs-agent" value="&lt;b&gt;IAgentFileSystem&lt;/b&gt; (agent 包)&lt;br&gt;最小化4方法契约（解耦接口）&lt;br&gt;readFile · writeFile · exists · readDir" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="330" y="755" width="230" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="edge-fs-agent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=1;dashed=1;endArrow=open;endFill=0;" edge="1" parent="1" source="fs-agent" target="fs-interface">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- FileServiceClient -->
    <mxCell id="fs-client" value="&lt;b&gt;FileServiceClient&lt;/b&gt; (web 包)&lt;br&gt;detectEnvironment() 自动选择:&lt;br&gt;1. window.electronAPI → Electron IPC&lt;br&gt;2. showDirectoryPicker → 浏览器FSA&lt;br&gt;3. 回退 → Server REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="620" y="840" width="210" height="60" as="geometry"/>
    </mxCell>

    <!-- ===== SECTION 4: 数据流 ===== -->
    <mxCell id="sec4-label" value="Agent 请求流程（端到端）" style="text;html=1;strokeColor=none;fillColor=#eeeeee;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="30" y="925" width="200" height="24" as="geometry"/>
    </mxCell>

    <!-- 流程步骤 -->
    <mxCell id="flow-1" value="1. 用户在&lt;br&gt;AgentPanel输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="960" width="105" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="flow-2" value="2. useAgent()&lt;br&gt;构建AgentContext&lt;br&gt;(打开文件、光标、树)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3ebf7;strokeColor=#9673a6;fontSize=8;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="155" y="955" width="125" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="flow-3" value="3. agentService&lt;br&gt;POST /api/agent/stream&lt;br&gt;(SSE 流式)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=8;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="300" y="955" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="flow-4" value="4. Server 路由&lt;br&gt;创建 Agent +&lt;br&gt;LocalFileSystem" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="440" y="955" width="110" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="flow-5" value="5. Agent多轮循环&lt;br&gt;工具调用执行&lt;br&gt;(最多15轮)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e0;strokeColor=#82b366;fontSize=8;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="570" y="955" width="110" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="flow-6" value="6. 大模型 API&lt;br&gt;OpenAI兼容接口&lt;br&gt;流式 + thinking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="700" y="955" width="115" height="50" as="geometry"/>
    </mxCell>

    <!-- 流程箭头 -->
    <mxCell id="edge-flow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="flow-1" target="flow-2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-flow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="flow-2" target="flow-3">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-flow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="flow-3" target="flow-4">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-flow-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="flow-4" target="flow-5">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="edge-flow-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="flow-5" target="flow-6">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- 返回流 -->
    <mxCell id="flow-return" value="响应流返回: SSE事件 → parseEditsFromText 解析编辑块 → 应用到编辑器标签页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=9;verticalAlign=middle;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="200" y="1025" width="400" height="24" as="geometry"/>
    </mxCell>

    <!-- 关键设计说明 -->
    <mxCell id="note" value="&lt;b&gt;关键设计决策:&lt;/b&gt;  • Agent 框架平台无关（通过 IAgentFileSystem 解耦）  • 三层文件系统: core IFileSystem → 3种实现 → web FileServiceClient  • SSE 流式 + 多轮工具调用循环  • MCP 协议实现可扩展工具生态  • 运行时环境自动检测（Electron / 浏览器 / 服务器）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=9;verticalAlign=middle;fontColor=#555555;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="30" y="1065" width="800" height="40" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>